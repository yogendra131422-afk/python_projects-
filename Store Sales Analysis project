# Mini Project: Store Sales Analysis

sales = [120, 85, 150, 90, 200, 75, 180, 110, 95, 160]

total = 0

highest = sales[0]
lowest = sales[0]

above_avg_count = 0
below_100_count = 0
between_100_149_count = 0
above_150_count = 0

# Total, Highest, Lowest

for x in sales:
    total = total + x

    if x > highest:
        highest = x

    if x < lowest:
        lowest = x

difference = highest - lowest

average = total / len(sales)

print("Above Average Sales:")

# Above Average Sales

for x in sales:
    if x > average:
        print(x)
        above_avg_count += 1


for x in sales:

    if x < 100:
        below_100_count += 1

    elif x >= 100 and x <= 149:
        between_100_149_count += 1

    else:  # x >= 150
        above_150_count += 1

print()
print("Total Sales =", total)
print("Highest Sales =", highest)
print("Lowest Sales =", lowest)
print("Difference =", difference)
print("Average Sales =", average)

print()
print("Above Average Count =", above_avg_count)

print()
print("Sales below 100 =", below_100_count)
print("Sales from 100 to 149 =", between_100_149_count)
print("Sales 150 and above =", above_150_count)
